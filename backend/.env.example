# === ElectionEdu Environment Variables ===

# DO NOT ADD YOUR REAL API KEY HERE.
# 1. Local Development: Copy this file, rename it to '.env', and paste your real key there.
#    (Make sure '.env' is in your .gitignore file so secrets aren't pushed to GitHub)
# 2. Production (Render/Railway): Do NOT upload .env files. Instead, add 'API_KEY' 
#    directly inside your hosting provider's dashboard under "Environment Variables".

API_KEY=your_api_key_here
